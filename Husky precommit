#!/bin/sh

# Check if triggered by Windows Git or native WSL Git
if command -v wsl.exe >/dev/null 2>&1 && [ ! -f "/proc/sys/fs/binfmt_misc/WSLInterop" ]; then
    # Route via Windows execution path into WSL
    echo "🔍 [Husky] Windows Git detected. Routing into WSL linting..."
    wsl.exe exec npx lint-staged
else
    # Route via native Linux/WSL execution path
    echo "🔍 [Husky] WSL Git detected. Running native linting..."
    npx lint-staged
fi
