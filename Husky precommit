#!/bin/sh

# Check if we are being called by Windows Git or a Windows-based IDE wrapper
if command -v wsl.exe >/dev/null 2>&1 && [ ! -f "/proc/sys/fs/binfmt_misc/WSLInterop" ]; then
    echo "🔍 [Husky] Windows Git detected. Bridging command into WSL..."
    # Force WSL to run npm via interactive bash so it inherits your node/npx environment paths
    wsl.exe bash -ic "npx --no-install lint-staged"
else
    echo "🔍 [Husky] WSL Git detected. Running native Linux lint-staged..."
    npx --no-install lint-staged
fi
