#!/bin/sh

# Detect if we are running from a Windows Git hook execution
if command -v wsl.exe >/dev/null 2>&1 && [ ! -f "/proc/sys/fs/binfmt_misc/WSLInterop" ]; then
    echo "🔍 [Husky] Windows Git detected. Executing via local project node_modules..."
    wsl.exe exec ./node_modules/.bin/lint-staged
else
    echo "🔍 [Husky] WSL Git/IDE detected. Executing natively..."
    ./node_modules/.bin/lint-staged
fi
