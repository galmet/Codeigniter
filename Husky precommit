#!/bin/sh
. "$(dirname "$0")/_/husky.sh"

# Check if we are running from a Windows process executing a WSL workspace
if command -v wsl.exe >/dev/null 2>&1 && [ ! -f "/proc/sys/fs/binfmt_misc/WSLInterop" ]; then
    # Triggered by Windows Git: Route lint-staged inside WSL
    echo "🔍 [Husky -> Windows Git] Routing linter into WSL..."
    wsl.exe exec npx lint-staged
else
    # Triggered by WSL Terminal or WSL-aware PhpStorm Git
    echo "🔍 [Husky -> WSL Git] Running linter natively..."
    npx lint-staged
fi
