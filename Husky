#!/bin/sh

# If triggered by Windows Git, bridge the path context into WSL cleanly
if command -v wsl.exe >/dev/null 2>&1 && [ ! -f "/proc/sys/fs/binfmt_misc/WSLInterop" ]; then
    
    # 1. Safely transform your Windows directory into a Linux directory string
    WSL_PATH=$(wsl.exe wslpath -u "$PWD")
    
    # 2. Execute lint-staged directly via absolute paths without loading profile files
    wsl.exe bash -c "cd '$WSL_PATH' && ./node_modules/.bin/lint-staged"
    
    # 3. Terminate the wrapper sequence early so Windows Git stops scanning
    exit $?
fi
