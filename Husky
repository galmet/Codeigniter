#!/bin/sh

# If this hook is being triggered by Windows Git, bridge it inside WSL instantly
if command -v wsl.exe >/dev/null 2>&1 && [ ! -f "/proc/sys/fs/binfmt_misc/WSLInterop" ]; then
    
    # 1. Convert the current Windows workspace path into a clean WSL Linux path string
    WSL_PATH=$(wsl.exe wslpath -u "$PWD")
    
    # 2. Re-execute lint-staged entirely inside the native Linux shell context
    wsl.exe bash -ic "cd '$WSL_PATH' && npx --no-install lint-staged"
    
    # 3. Exit the parent Windows hook process early so it doesn't try to look for local Windows files
    exit $?
fi
